# Flattens node_modules (hoists all packages to the root).
# Required for Storybook + webpack with pnpm: without this, pnpm isolates each
# package in its own node_modules subtree, causing webpack to bundle multiple
# copies of React — one per resolution context — which triggers the runtime
# error "Cannot read properties of undefined (reading 'ReactCurrentDispatcher')".
shamefully-hoist=true

# Pin every installed dependency to its exact version (no ^ or ~ ranges).
save-exact=true